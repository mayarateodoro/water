cube_tiles <- tile$tile
cube2024 <- sits_cube(
  source = "BDC",
  collection = "SENTINEL-2-16D",
  bands = c("B02","B03","B04","B05","B06","B07","B08","B8A","B11","B12","CLOUD","NDVI"),
