#18 ESTATÍSTICA
# 1. Carregar os dados
r <- rast('resultados/mapas/agua_alta_confianca.tif')
gpkg_ref <- vect("dados_brutos/vetores/hidrografia_planalto_central.gpkg")

# 2. Tratar NAs como 0
r[is.na(r)] <- 0

# 3. Alinhar o CRS
if (crs(r) != crs(gpkg_ref)) {
  cat("Alinhando sistemas de coordenadas... Aguarde.\n")
  gpkg_ref <- project(gpkg_ref, crs(r))
}

# 4. CÁLCULO DAS ÁREAS TOTAIS 

res_pixel <- res(r)[1] * res(r)[2]

# Área do Raster (Mapeada)
pixels_agua <- global(r, "sum", na.rm = TRUE)$sum
area_raster_ha <- (pixels_agua * res_pixel) / 10000

# Área do GeoPackage (Referência)
area_gpkg_ha <- sum(expanse(gpkg_ref)) / 10000

# 5. Cálculo de omissão (HIDROGRAFIA - MAPA) 

cat("\nCalculando erros de Omissão...\n")
gpkg_rasterizado <- rasterize(gpkg_ref, r, field = 1, background = 0)

# Omissão: O que a referência tem (1) e você não pegou (0)
omissao_raster <- gpkg_rasterizado - r
omissao_raster[omissao_raster <= 0] <- NA

pixels_erro_omissao <- global(omissao_raster, "sum", na.rm = TRUE)$sum
area_omissao_ha <- (pixels_erro_omissao * res_pixel) / 10000

# 6. Cálculo das estatísticas de acurácia 

# Área de Acerto (O que ambos concordam que é água)
# Hidrografia Total - O que você não pegou = O que você acertou
area_acerto_ha <- area_gpkg_ha - area_omissao_ha

# Área de Comissão (O que você mapeou mas não está no oficial)
area_comissao_ha <- area_raster_ha - area_acerto_ha

# Cálculos de Porcentagem
p_acerto   <- (area_acerto_ha / area_gpkg_ha) * 100
p_omissao  <- (area_omissao_ha / area_gpkg_ha) * 100
p_comissao <- (area_comissao_ha / area_raster_ha) * 100

# 7. Resultados

cat("\n--- ESTATÍSTICAS DE ÁREA (HA) ---\n")
cat("Área Hidrografia (Ref):", round(area_gpkg_ha, 2), "ha\n")
cat("Área Mapeada (Raster): ", round(area_raster_ha, 2), "ha\n")
cat("Acerto Real:           ", round(area_acerto_ha, 2), "ha\n")
cat("Erro de Omissão:       ", round(area_omissao_ha, 2), "ha\n")
cat("Erro de Comissão:      ", round(area_comissao_ha, 2), "ha\n")

cat("\n========= RELATÓRIO DE ACURÁCIA (%) =========\n")
cat("Exatidão do Produtor (Acerto): ", round(p_acerto, 2), "%\n")
cat("Erro de Omissão (Não detectado):", round(p_omissao, 2), "%\n")
cat("Erro de Comissão (Falsos/Novos):", round(p_comissao, 2), "%\n")
cat("==============================================\n")

# 8. Salva o projeto

cat("\nGerando polígono de omissão para conferência no QGIS...\n")
